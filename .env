# ════════════════════════════════════════════════════════════
# VARCAVIA — Variabili di Ambiente (Sviluppo Locale)
# ════════════════════════════════════════════════════════════

# Logging
RUST_LOG=info
VARCAVIA_LOG=debug

# Nodo
VARCAVIA_NODE_NAME=varcavia-dev-01
VARCAVIA_DATA_DIR=~/varcavia-data/node-01

# Rete
VARCAVIA_LISTEN_ADDR=127.0.0.1
VARCAVIA_LISTEN_PORT=7700

# API
VARCAVIA_API_ADDR=127.0.0.1:8080

# AI Agents
VARCAVIA_AGENT_SOCKET=/tmp/varcavia-agent.sock
VARCAVIA_ONNX_MODEL=models/all-MiniLM-L6-v2.onnx

# Storage
VARCAVIA_DB_PATH=~/varcavia-data/node-01/db
VARCAVIA_MAX_STORAGE_GB=10
